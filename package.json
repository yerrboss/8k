{
  "name": "wall-screen-8k-ui",
  "version": "1.0.4",
  "description": "Salrayworks VaDA 8K Video Wall UI",
  "author": "Salrayworks",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
